PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/smart_recruitment_portal
JWT_SECRET=supersecretjwtkey_123456789_change_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Cloudinary (Optional, local storage fallback if empty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP Email Config (Optional, will mock/log to console if empty)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@smartrecruit.com
